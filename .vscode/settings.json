{
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "chat.disableAIFeatures": true,
  "editor.indentSize": "tabSize",
  "editor.tabSize": 2,
  "editor.guides.bracketPairs": true,
  "editor.insertSpaces": true,
  "editor.rulers": [
    120
  ],
  "editor.semanticHighlighting.enabled": true,
  "editor.unicodeHighlight.invisibleCharacters": true,
  "editor.wordWrapColumn": 120,
  "extensions.allowed": {
    "amazonwebservices.amazon-q-vscode": false,
    "Anthropic.claude-code": false,
    "blackboxapp.blackboxagent": false,
    "codeium.codeium": false,
    "continue.continue": false,
    "feiskyer.chatgpt-copilot": false,
    "ghutu.perplexity-ext": false,
    "github.copilot": false,
    "github.copilot-chat": false,
    "google.geminicodeassist": false,
    "google.gemini-cli-vscode-ide-companion": false,
    "ibm.wca-core": false,
    "ms-azuretools.vscode-azure-github-copilot": false,
    "ms-windows-ai-studio.windows-ai-studio": false,
    "openai.chatgpt": false,
    "qwenlm.qwen-code-vscode-ide-companion": false,
    "rooveterinaryinc.roo-cline": false,
    "saoudrizwan.claude-dev": false,
    "sixth.sixth-ai": false,
    "wassimdev.wassimdev-vscode-deepseek": false
  },
  "extension-uninstaller.uninstall": [
    "Alibaba-Cloud.tongyi-lingma",
    "amazonwebservices.amazon-q-vscode",
    "AndrePimenta.claude-code-chat",
    "Anthropic.claude-code",
    "BaiduComate.comate",
    "blackboxapp.blackboxagent",
    "codeium.codeium",
    "continue.continue",
    "DanielSanMedium.dscodegpt",
    "feiskyer.chatgpt-copilot",
    "FittenTech.Fitten-Code",
    "ghutu.perplexity-ext",
    "github.copilot",
    "github.copilot-chat",
    "google.geminicodeassist",
    "google.gemini-cli-vscode-ide-companion",
    "ibm.wca-core",
    "Keploy.keployio",
    "kilocode.Kilo-Code",
    "ktiays.aicursor",
    "MarsCode.marscode-extension",
    "ms-azuretools.vscode-azure-github-copilot",
    "ms-windows-ai-studio.windows-ai-studio",
    "openai.chatgpt",
    "qwenlm.qwen-code-vscode-ide-companion",
    "QxLabAI.text2code",
    "rooveterinaryinc.roo-cline",
    "saoudrizwan.claude-dev",
    "sixth.sixth-ai",
    "sourcegraph.cody-ai",
    "Tencent-Cloud.coding-copilot",
    "wassimdev.wassimdev-vscode-deepseek",
    "ZencoderAI.zencoder"
  ],
  "files.autoSave": "afterDelay",
  "files.eol": "\n",
  "files.exclude": {
    "**/.git": true,
    "**/.gitignore": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/.python-version": true,
    "**/.venv": true,
    "**/.vscode": true,
    "**/pyproject.toml": true,
    "**/Thumbs.db": true,
    "**/uv.lock": true
  },
  "files.readonlyInclude": {
    "**/.gitignore": true,
    "**/.python-version": true,
    "**/.vscode": true,
    "**/pyproject.toml": true,
    "**/uv.lock": true
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "python.analysis.ignore": [
    "*"
  ],
  "python.analysis.typeCheckingMode": "strict",
  "python.languageServer": "Pylance",
  "python.useEnvironmentsExtension": true,
  "python-envs.alwaysUseUv": true,
  "telemetry.telemetryLevel": "off",
  "workbench.startupEditor": "readme"
}
